# ── Banco de Dados (PostgreSQL) ──────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=jobprospector
DB_USER=postgres
DB_PASSWORD=change

# ── PostgreSQL Docker (usado pelo docker-compose) ─────────────────────────────
POSTGRES_DB=jobprospector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change

# ── Apollo.io API ─────────────────────────────────────────────────────────────
# Obtenha sua chave em: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=your_apollo_api_key_here

# ── E-mail SMTP ───────────────────────────────────────────────────────────────
# Gmail: use uma App Password (não sua senha pessoal)
# Gere em: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=your@gmail.com
SMTP_SENDER_PASSWORD=your-password
SMTP_SENDER_NAME=Job Prospector
